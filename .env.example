# Copy to .env.local. Never commit real keys.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
TEACHER_ACCESS_CODE=

# Runtime provider: openai | lmstudio | fallback
# Production and the final judging demo should use openai.
AI_PROVIDER=openai
MODERATION_PROVIDER=openai

# Cost-free local development with LM Studio:
# AI_PROVIDER=lmstudio
# MODERATION_PROVIDER=local
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=google/gemma-4-e4b
LM_STUDIO_API_KEY=lm-studio
